# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# IMPORTANTE: Copiar este archivo a .env.production y configurar valores reales

# Database Configuration
DATABASE_URL=postgresql://bolsillo_claro:PASSWORD_AQUI@localhost:5432/bolsillo_claro_production?sslmode=disable

# JWT Configuration
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_SUPER_LARGO_Y_SEGURO_64_CARACTERES_MINIMO
JWT_REFRESH_SECRET=OTRO_STRING_ALEATORIO_DIFERENTE_SUPER_LARGO_Y_SEGURO_64_CARACTERES

# Server Configuration
PORT=8080
GIN_MODE=release

# CORS Configuration (dominios permitidos)
CORS_ALLOWED_ORIGINS=https://rubsoftware.online,https://api.rubsoftware.online,http://192.168.0.46:5173

# Frontend URL used to build verification and password-reset links
FRONTEND_URL=https://rubsoftware.online

# Email delivery (production preferred path)
# Set BREVO_API_KEY on Render to use Brevo's HTTPS transactional API.
# Keep SMTP_* only as a backwards-compatible fallback when BREVO_API_KEY is empty.
BREVO_API_KEY=CONFIGURAR_EN_RENDER_NO_COMMITTEAR
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Avaltra <auth@rubsoftware.online>
