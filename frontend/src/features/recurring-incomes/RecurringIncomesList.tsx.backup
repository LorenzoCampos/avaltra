import { useState, useMemo } from 'react';
import { useNavigate } from 'react-router-dom';
import { toast } from 'sonner';
import { useRecurringIncomes, useDeleteRecurringIncome, useUpdateRecurringIncome } from '@/hooks/useRecurringIncomes';
import { useDeleteAnimation } from '@/hooks/useDeleteAnimation';
import { useAccountStore } from '@/stores/account.store';
import { Button } from '@/components/ui/Button';
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/Card';
import { TableSkeleton } from '@/components/ui/Skeleton';
import type { RecurringIncome, RecurrenceFrequency } from '@/types/recurringIncome';

// Helper function to format recurrence label
const formatRecurrenceLabel = (item: RecurringIncome): string => {
  const { recurrence_frequency, recurrence_interval, recurrence_day_of_month, recurrence_day_of_week } = item;
  
  const intervalText = recurrence_interval > 1 ? `${recurrence_interval} ` : '';
  
  switch (recurrence_frequency) {
    case 'daily':
      return `Every ${intervalText}day${recurrence_interval > 1 ? 's' : ''}`;
    case 'weekly': {
      const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
      const day = recurrence_day_of_week !== undefined && recurrence_day_of_week !== null ? days[recurrence_day_of_week] : '';
      return `Every ${intervalText}week${recurrence_interval > 1 ? 's' : ''} on ${day}`;
    }
    case 'monthly': {
      const dayOfMonth = recurrence_day_of_month || 1;
      return `Every ${intervalText}month${recurrence_interval > 1 ? 's' : ''} on day ${dayOfMonth}`;
    }
    case 'yearly': {
      const dayOfMonth = recurrence_day_of_month || 1;
      return `Every ${intervalText}year${recurrence_interval > 1 ? 's' : ''} on day ${dayOfMonth}`;
    }
    default:
      return recurrence_frequency;
  }
};

export const RecurringIncomesList = () => {
  const navigate = useNavigate();
  const { activeAccount } = useAccountStore();
  const [activeFilter, setActiveFilter] = useState<'true' | 'false' | 'all'>('true');
  const [frequencyFilter, setFrequencyFilter] = useState<RecurrenceFrequency | 'all'>('all');
  
  const { data, isLoading, error } = useRecurringIncomes({ 
    is_active: activeFilter,
    frequency: frequencyFilter === 'all' ? undefined : frequencyFilter
  });
  
  const { mutate: deleteRecurringIncome, isPending: isDeleting } = useDeleteRecurringIncome();
  const { mutate: updateRecurringIncome, isPending: isUpdating } = useUpdateRecurringIncome();
  const { handleDelete: handleDeleteWithAnimation, isDeleting: isAnimatingDelete } = useDeleteAnimation();

  const recurringIncomes = data?.recurring_incomes || [];
  const total = data?.total || 0;
  
  // Calculate summary
  const activeIncomes = useMemo(() => recurringIncomes.filter(i => i.is_active), [recurringIncomes]);
  
  // Calculate monthly total with accurate exchange rates
  const monthlyTotal = useMemo(() => {
    if (!activeAccount) return 0;
    
    return activeIncomes.reduce((sum, income) => {
      // Determine the amount in primary currency
      let amountInPrimary: number;
      
      if (income.currency === activeAccount.currency) {
        // Same currency, use amount directly
        amountInPrimary = income.amount;
      } else if (income.amount_in_primary_currency) {
        // ✅ ACCURATE: Use the real amount_in_primary_currency from backend
        amountInPrimary = income.amount_in_primary_currency;
      } else if (income.exchange_rate) {
        // Use exchange_rate if available
        amountInPrimary = income.amount * income.exchange_rate;
      } else {
        // Last resort: use original amount (shouldn't happen)
        amountInPrimary = income.amount;
      }
      
      // Calculate monthly income based on frequency
      let monthlyIncome = amountInPrimary;
      switch (income.recurrence_frequency) {
        case 'daily':
          monthlyIncome = amountInPrimary * 30 / income.recurrence_interval;
          break;
        case 'weekly':
          monthlyIncome = amountInPrimary * 4 / income.recurrence_interval;
          break;
        case 'monthly':
          monthlyIncome = amountInPrimary / income.recurrence_interval;
          break;
        case 'yearly':
          monthlyIncome = amountInPrimary / (12 * income.recurrence_interval);
          break;
      }
      
      return sum + monthlyIncome;
    }, 0);
  }, [activeIncomes, activeAccount]);

  const handleEdit = (e: React.MouseEvent, id: string) => {
    e.stopPropagation();
    navigate(`/incomes/recurring/edit/${id}`);
  };

  const handleToggleActive = (e: React.MouseEvent, income: RecurringIncome) => {
    e.stopPropagation();
    const newStatus = !income.is_active;
    updateRecurringIncome({
      id: income.id,
      is_active: newStatus,
    }, {
      onSuccess: () => {
        toast.success(`Recurring income ${newStatus ? 'activated' : 'deactivated'}`);
      },
    });
  };

  const handleDelete = (e: React.MouseEvent, id: string, description: string) => {
    e.stopPropagation();
    if (window.confirm(`Are you sure you want to delete the recurring income "${description}"?`)) {
      handleDeleteWithAnimation(id, () => deleteRecurringIncome(id));
    }
  };

  if (!activeAccount) {
    return (
      <div className="text-center py-20">
        <div className="p-6 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg max-w-md mx-auto">
          <h3 className="text-lg font-medium text-gray-800 dark:text-gray-200 mb-2">No Active Account</h3>
          <p className="text-gray-600 dark:text-gray-400 mb-4">Please select or create an account first</p>
          <Button onClick={() => navigate('/accounts')}>
            Go to Accounts
          </Button>
        </div>
      </div>
    );
  }

  if (isLoading) {
    return (
      <div className="space-y-6">
        <div className="flex justify-between items-center">
          <div>
            <h1 className="text-2xl font-bold text-gray-900 dark:text-white">Recurring Incomes</h1>
            <p className="text-sm text-gray-600 dark:text-gray-400 mt-1">Account: {activeAccount.name}</p>
          </div>
          <Button onClick={() => navigate('/incomes/recurring/new')}>
            + Add Recurring Income
          </Button>
        </div>

        <Card>
          <CardHeader>
            <CardTitle>All Recurring Incomes</CardTitle>
          </CardHeader>
          <CardContent>
            <TableSkeleton rows={8} />
          </CardContent>
        </Card>
      </div>
    );
  }

  if (error) {
    const errorMessage = (error as any)?.response?.data?.error || (error as any)?.message || 'Failed to load recurring incomes';
    return (
      <div className="text-center py-10">
        <div className="p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg">
          <h3 className="text-lg font-medium text-red-800 dark:text-red-400 mb-2">Error Loading Recurring Incomes</h3>
          <p className="text-red-600 dark:text-red-300">{errorMessage}</p>
        </div>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      <div className="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
        <div>
          <h1 className="text-2xl font-bold text-gray-900 dark:text-white">Recurring Incomes</h1>
          <p className="text-sm text-gray-600 dark:text-gray-400 mt-1">Account: {activeAccount.name}</p>
        </div>
        <Button onClick={() => navigate('/incomes/recurring/new')}>
          + Add Recurring Income
        </Button>
      </div>

      {/* Summary Card */}
      {activeIncomes.length > 0 && (
        <Card className="bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 border-green-200 dark:border-green-800">
          <CardContent className="py-4">
            <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div>
                <p className="text-xs text-gray-600 dark:text-gray-400 uppercase font-semibold">Active Templates</p>
                <p className="text-2xl font-bold text-green-600 dark:text-green-400">{activeIncomes.length}</p>
              </div>
              <div>
                <p className="text-xs text-gray-600 dark:text-gray-400 uppercase font-semibold">Estimated Monthly</p>
                <p className="text-2xl font-bold text-green-600 dark:text-green-400">
                  {activeAccount.currency} {monthlyTotal.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                </p>
              </div>
              <div>
                <p className="text-xs text-gray-600 dark:text-gray-400 uppercase font-semibold">Total Generated</p>
                <p className="text-2xl font-bold text-green-600 dark:text-green-400">
                  {activeIncomes.reduce((sum, i) => sum + (i.current_occurrence || 0), 0)}
                </p>
              </div>
            </div>
          </CardContent>
        </Card>
      )}

      {/* Filters */}
      <div className="flex flex-col sm:flex-row gap-4">
        {/* Active/Inactive Filter */}
        <div className="flex gap-2">
          <button
            onClick={() => setActiveFilter('true')}
            className={`px-4 py-2 text-sm font-medium rounded-md transition-colors ${
              activeFilter === 'true'
                ? 'bg-blue-600 text-white'
                : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600'
            }`}
          >
            Active
          </button>
          <button
            onClick={() => setActiveFilter('false')}
            className={`px-4 py-2 text-sm font-medium rounded-md transition-colors ${
              activeFilter === 'false'
                ? 'bg-blue-600 text-white'
                : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600'
            }`}
          >
            Inactive
          </button>
          <button
            onClick={() => setActiveFilter('all')}
            className={`px-4 py-2 text-sm font-medium rounded-md transition-colors ${
              activeFilter === 'all'
                ? 'bg-blue-600 text-white'
                : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600'
            }`}
          >
            All
          </button>
        </div>

        {/* Frequency Filter */}
        <select
          value={frequencyFilter}
          onChange={(e) => setFrequencyFilter(e.target.value as RecurrenceFrequency | 'all')}
          className="px-4 py-2 text-sm font-medium rounded-md bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500"
        >
          <option value="all">All Frequencies</option>
          <option value="daily">Daily</option>
          <option value="weekly">Weekly</option>
          <option value="monthly">Monthly</option>
          <option value="yearly">Yearly</option>
        </select>
      </div>

      {recurringIncomes.length === 0 ? (
        <Card>
          <CardContent className="py-20 text-center">
            <h3 className="text-lg font-medium text-gray-800 dark:text-gray-200 mb-2">
              {activeFilter === 'false' ? 'No Inactive Recurring Incomes' : 'No Recurring Incomes Yet'}
            </h3>
            <p className="text-gray-600 dark:text-gray-400 mb-4">
              {activeFilter === 'false' 
                ? 'You have no deactivated recurring incomes'
                : 'Start automating your income tracking by adding a recurring income'
              }
            </p>
            {activeFilter !== 'false' && (
              <Button onClick={() => navigate('/incomes/recurring/new')}>
                Add Your First Recurring Income
              </Button>
            )}
          </CardContent>
        </Card>
      ) : (
        <>
          {/* Desktop Table View */}
          <Card className="hidden md:block">
            <CardHeader>
              <CardTitle>
                {activeFilter === 'true' ? 'Active' : activeFilter === 'false' ? 'Inactive' : 'All'} Recurring Incomes ({total})
              </CardTitle>
            </CardHeader>
            <CardContent>
              <div className="overflow-x-auto">
                <table className="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                  <thead className="bg-gray-50 dark:bg-gray-700">
                    <tr>
                      <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Description
                      </th>
                      <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Amount
                      </th>
                      <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Frequency
                      </th>
                      <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Category
                      </th>
                      <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Status
                      </th>
                      <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Occurrences
                      </th>
                      <th className="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Actions
                      </th>
                    </tr>
                  </thead>
                  <tbody className="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                    {recurringIncomes.map((income, index) => (
                      <tr 
                        key={income.id} 
                        className={`hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors ${
                          isAnimatingDelete(income.id) ? 'animate-slide-out-left' : 'animate-slide-up'
                        } ${
                          index < 5 ? `animation-delay-${index * 100}` : ''
                        }`}
                      >
                        <td className="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">
                          {income.description}
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap text-sm font-semibold text-green-600 dark:text-green-400">
                          {income.currency} {(income.amount ?? 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                          {formatRecurrenceLabel(income)}
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                          {income.category_name || 'No Category'}
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap text-sm">
                          <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                            income.is_active
                              ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400'
                              : 'bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-400'
                          }`}>
                            {income.is_active ? 'Active' : 'Inactive'}
                          </span>
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                          {income.current_occurrence || 0}
                          {income.total_occurrences ? ` / ${income.total_occurrences}` : ' / ∞'}
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                          <button
                            onClick={(e) => handleToggleActive(e, income)}
                            className={`${
                              income.is_active
                                ? 'text-orange-600 dark:text-orange-400 hover:text-orange-900 dark:hover:text-orange-300'
                                : 'text-green-600 dark:text-green-400 hover:text-green-900 dark:hover:text-green-300'
                            } transition-colors disabled:opacity-50`}
                            disabled={isUpdating}
                            title={income.is_active ? 'Deactivate' : 'Activate'}
                          >
                            {income.is_active ? 'Pause' : 'Resume'}
                          </button>
                          <button
                            onClick={(e) => handleEdit(e, income.id)}
                            className="text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300 transition-colors"
                          >
                            Edit
                          </button>
                          <button
                            onClick={(e) => handleDelete(e, income.id, income.description)}
                            className="text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300 transition-colors disabled:opacity-50"
                            disabled={isDeleting}
                          >
                            Delete
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </CardContent>
          </Card>

          {/* Mobile Card View */}
          <div className="md:hidden space-y-4">
            <div className="flex items-center justify-between px-1">
              <h2 className="text-lg font-semibold text-gray-900 dark:text-white">
                {activeFilter === 'true' ? 'Active' : activeFilter === 'false' ? 'Inactive' : 'All'} ({total})
              </h2>
            </div>
            {recurringIncomes.map((income, index) => (
              <div
                key={income.id}
                className={`bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 shadow-sm ${
                  isAnimatingDelete(income.id) ? 'animate-slide-out-left' : 'animate-slide-up'
                } ${
                  index < 5 ? `animation-delay-${index * 100}` : ''
                }`}
              >
                <div className="flex items-start justify-between mb-3">
                  <div className="flex-1 min-w-0">
                    <h3 className="font-semibold text-gray-900 dark:text-white truncate">
                      {income.description}
                    </h3>
                    <p className="text-sm text-gray-500 dark:text-gray-400 mt-1">
                      {formatRecurrenceLabel(income)}
                    </p>
                  </div>
                  <div className="text-right ml-4">
                    <p className="text-lg font-bold text-green-600 dark:text-green-400 whitespace-nowrap">
                      {income.currency} {(income.amount ?? 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                    </p>
                  </div>
                </div>

                <div className="flex flex-wrap gap-2 mb-3">
                  <span className="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300">
                    {income.category_name || 'No Category'}
                  </span>
                  <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                    income.is_active
                      ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400'
                      : 'bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-400'
                  }`}>
                    {income.is_active ? 'Active' : 'Inactive'}
                  </span>
                  <span className="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300">
                    {income.current_occurrence || 0}
                    {income.total_occurrences ? ` / ${income.total_occurrences}` : ' / ∞'}
                  </span>
                </div>

                <div className="flex gap-2">
                  <button
                    onClick={(e) => handleToggleActive(e, income)}
                    className={`flex-1 px-3 py-2 text-sm font-medium rounded-md transition-colors disabled:opacity-50 ${
                      income.is_active
                        ? 'text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/30 hover:bg-orange-100 dark:hover:bg-orange-900/50'
                        : 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/30 hover:bg-green-100 dark:hover:bg-green-900/50'
                    }`}
                    disabled={isUpdating}
                  >
                    {income.is_active ? '⏸ Pause' : '▶ Resume'}
                  </button>
                  <button
                    onClick={(e) => handleEdit(e, income.id)}
                    className="flex-1 px-3 py-2 text-sm font-medium text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 rounded-md hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors"
                  >
                    Edit
                  </button>
                  <button
                    onClick={(e) => handleDelete(e, income.id, income.description)}
                    className="flex-1 px-3 py-2 text-sm font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/30 rounded-md hover:bg-red-100 dark:hover:bg-red-900/50 transition-colors disabled:opacity-50"
                    disabled={isDeleting}
                  >
                    Delete
                  </button>
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  );
};
